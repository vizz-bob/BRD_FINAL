# ── .env files: INCLUDED in git for deployment convenience ──────────────────
# The .env files contain non-sensitive staging credentials and must be
# committed so that EC2 can run without a manual setup step.
# For production, rotate secrets and use AWS Secrets Manager instead.
# (Lines below explicitly UN-ignore .env)
!.env
!**/.env

# ── .env.local files: LOCAL DEV ONLY — never push to git ────────────────────
# These override .env for localhost development (DB_HOST=localhost, etc.)
.env.local
**/.env.local

# ── Local dev scripts ─────────────────────────────────────────────────────────
.local-logs/
