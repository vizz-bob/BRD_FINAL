server {
    listen 80;
    server_name 13.232.219.91;

    # Redirect without trailing slash
    location = /master-admin {
        return 301 /master-admin/;
    }

    # Static assets (React build)
    location /master-admin/assets/ {
        root /var/www/html;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
        try_files $uri =404;
    }

    # React app
    location /master-admin/ {
        root /var/www/html;
        index index.html;
        try_files $uri $uri/ /master-admin/index.html;
    }

    # Optional: main website
    location / {
        root /var/www/html/website;
        index index.html;
        try_files $uri $uri/ /index.html;
    }
}
